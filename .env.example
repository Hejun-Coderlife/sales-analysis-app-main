AI_API_KEY=your_new_api_key_here
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
PORT=3000
# 生产示例：https://app.hemei.asia（不配则服务端默认使用该域名生成对外链接）
PUBLIC_BASE_URL=http://localhost:3000
# DingTalk internal app — work notification test (do not commit real secrets)
DINGTALK_CORP_ID=
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_AGENT_ID=
DINGTALK_TEST_USER_ID=
# 端内免登：钉钉「网页应用移动端首页」与「端内免登地址」均建议填与 env.publishedMobileUrl 一致的完整 URL（未设 PUBLIC_BASE_URL 时默认 https://app.hemei.asia/mobile）。
# GET /mobile 携带 code / authCode / auth_code 即完成免登。兼容旧路径 GET /dingtalk/login（会 302 到 /mobile）。
# 管理员：GET /dingtalk/admin-login?next=/admin ；可选 OAuth 回调：GET /dingtalk/callback
# Optional defaults for notification module
DINGTALK_NOTIFY_CHANNEL_ENABLED=true
DATA_DIR=./data
UPLOAD_DIR=./backend/data/uploads
DUCKDB_PATH=./backend/data/analytics.duckdb
ANALYTICS_PATH_MODE=legacy
ANALYTICS_ENABLE_SHADOW_PARITY=false
MAX_UPLOAD_MB=100
ANALYTICS_CACHE_TTL_MS=20000
SESSION_SECRET=change-this-session-secret
SESSION_MAX_AGE_MS=43200000
# memory | file — Windows defaults to memory (avoids session-file-store rename/EPERM). Others default to file.
SESSION_STORE=memory
# In-memory AI chat state: expire after idle (ms); cap concurrent conversations (process-wide).
CHAT_STATE_TTL_MS=14400000
CHAT_MAX_CONVERSATIONS=500
# Per-user POST /api/chat limit (sliding window).
CHAT_API_RATE_WINDOW_MS=60000
CHAT_API_MAX_PER_WINDOW=20
