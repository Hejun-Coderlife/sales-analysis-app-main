AI_API_KEY=your_new_api_key_here
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
# DingTalk internal app — work notification test (do not commit real secrets)
DINGTALK_CORP_ID=
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_AGENT_ID=
DINGTALK_TEST_USER_ID=
# Optional defaults for notification module
DINGTALK_NOTIFY_CHANNEL_ENABLED=true
DATA_DIR=./data
UPLOAD_DIR=./backend/data/uploads
DUCKDB_PATH=./backend/data/analytics.duckdb
ANALYTICS_PATH_MODE=legacy
ANALYTICS_ENABLE_SHADOW_PARITY=false
MAX_UPLOAD_MB=100
ANALYTICS_CACHE_TTL_MS=20000
SESSION_SECRET=change-this-session-secret
SESSION_MAX_AGE_MS=43200000
# memory | file — Windows defaults to memory (avoids session-file-store rename/EPERM). Others default to file.
SESSION_STORE=memory
